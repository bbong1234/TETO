{
  "version": "1.6.0",
  "description": "TETO 1.6 设计令牌 — 唯一设计变量来源。Web 和 iOS（远期）共享同一套设计符号。",

  "color": {
    "brand": {
      "primary": "#6366f1",
      "primaryLight": "#a5b4fc",
      "primarySoft": "rgba(99, 102, 241, 0.15)"
    },
    "status": {
      "active": "#3b82f6",
      "progressing": "#8b5cf6",
      "slowing": "#f59e0b",
      "stagnant": "#ef4444",
      "completed": "#22c55e",
      "shelved": "#6b7280"
    },
    "confidence": {
      "high": "#22c55e",
      "medium": "#f59e0b",
      "low": "#ef4444"
    },
    "trust": {
      "trusted": "#22c55e",
      "reviewed": "#3b82f6",
      "unchecked": "#6b7280",
      "disputed": "#ef4444"
    },
    "semantic": {
      "success": "#22c55e",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#3b82f6"
    },
    "neutral": {
      "50": "#f9fafb",
      "100": "#f3f4f6",
      "200": "#e5e7eb",
      "300": "#d1d5db",
      "400": "#9ca3af",
      "500": "#6b7280",
      "600": "#4b5563",
      "700": "#374151",
      "800": "#1f2937",
      "900": "#111827"
    }
  },

  "font": {
    "family": {
      "sans": "'Inter', system-ui, -apple-system, sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "weight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    }
  },

  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem",
    "16": "4rem"
  },

  "radius": {
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "full": "9999px"
  },

  "shadow": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1)"
  },

  "opacity": {
    "disabled": "0.5",
    "hover": "0.8",
    "muted": "0.6"
  },

  "motion": {
    "duration": {
      "fast": "150ms",
      "normal": "250ms",
      "slow": "350ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },

  "zIndex": {
    "base": "0",
    "dropdown": "100",
    "sticky": "200",
    "overlay": "300",
    "modal": "400",
    "toast": "500",
    "tooltip": "600"
  },

  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "icon": {
    "size": {
      "xs": "0.75rem",
      "sm": "1rem",
      "md": "1.25rem",
      "lg": "1.5rem",
      "xl": "2rem"
    }
  },

  "chart": {
    "series": [
      "#818cf8",
      "#34d399",
      "#fbbf24",
      "#c084fc",
      "#fb7185",
      "#22d3ee"
    ],
    "grid": "#f1f5f9",
    "tick": "#94a3b8",
    "tooltipBorder": "#e2e8f0"
  },

  "surface": {
    "gradient": [
      "#f0f4f8",
      "#e8edf5",
      "#f5f0ff",
      "#eef2ff"
    ],
    "glass": "rgba(255, 255, 255, 0.72)",
    "glassHeavy": "rgba(255, 255, 255, 0.85)",
    "glassDark": "rgba(15, 23, 42, 0.65)"
  }
}

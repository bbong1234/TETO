# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Development Mode
# DEV_MODE=true                          # Server-side: controls service_role key usage (bypasses RLS)
# NEXT_PUBLIC_DEV_MODE=true              # Client-side: controls login bypass UI
# NEXT_PUBLIC_DEV_USER_ID=your-test-user-id
